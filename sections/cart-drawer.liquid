<div class="cart-drawer-inner flex flex-col h-full">
  {%- assign gift_wrap_id = settings.global_gift_wrap_variant_id | plus: 0 -%}
  {%- assign effective_item_count = 0 -%}

  {%- for item in cart.items -%}
    {%- unless item.variant_id == gift_wrap_id -%}
      {%- assign effective_item_count = effective_item_count | plus: item.quantity -%}
    {%- endunless -%}
  {%- endfor -%}

  <div class="flex items-center justify-between px-5 py-4 border-b border-bark/10 flex-shrink-0">
    <div class="flex items-center gap-2">
      <span class="font-display text-lg font-bold text-bark">Your Cart</span>
      {%- if effective_item_count > 0 -%}
        <span
          class="bg-custom-green text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center"
          id="drawer-item-count"
        >
          {{ effective_item_count }}
        </span>
      {%- endif -%}
    </div>
    <button
      class="cart-drawer-close w-8 h-8 rounded-full border border-bark/10 flex items-center justify-center text-sm text-bark hover:bg-sand transition-colors cursor-pointer"
      aria-label="Close cart"
    >
      ✕
    </button>
  </div>

  <div class="flex-1 overflow-y-auto px-5 py-4">
    {%- if cart.item_count > 0 -%}
      <div class="space-y-0 divide-y divide-bark/8">
        {%- for item in cart.items -%}
          {%- unless item.properties._gift_wrap == 'true' -%}
            <div
              class="cart-drawer-item flex gap-3 py-4"
              id="drawer-item-{{ item.key }}"
            >
              <a href="{{ item.url }}" class="w-16 h-16 rounded-xl overflow-hidden bg-sand flex-shrink-0 block">
                {%- if item.image -%}
                  {{
                    item.image
                    | image_url: width: 160
                    | image_tag: class: 'w-full h-full object-cover', alt: item.image.alt, loading: 'lazy'
                  }}
                {%- else -%}
                  <div class="w-full h-full flex items-center justify-center text-2xl">🥭</div>
                {%- endif -%}
              </a>

              <div class="flex-1 min-w-0">
                <a
                  href="{{ item.url }}"
                  class="block text-sm font-medium text-bark hover:text-custom-green transition-colors leading-tight mb-0.5 truncate"
                >
                  {{ item.product.title }}
                </a>
                {%- unless item.product.has_only_default_variant -%}
                  <div class="text-xs text-bark/50 mb-1">{{ item.variant.title }}</div>
                {%- endunless -%}
                {%- if item.properties.size > 0 -%}
                  <div class="mb-1">
                    {%- for property in item.properties -%}
                      {%- unless property.last == blank -%}
                        <div class="text-[10px] text-bark/45">{{ property.first }}: {{ property.last }}</div>
                      {%- endunless -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                <!-- Price + Qty controls -->
                <div class="flex items-center justify-between mt-2">
                  <div class="flex items-center border border-bark/15 rounded-lg overflow-hidden">
                    <button
                      class="drawer-qty-btn w-6 h-6 bg-sand flex items-center justify-center text-bark text-xs hover:bg-sand-dark transition-colors cursor-pointer"
                      data-item-key="{{ item.key }}"
                      data-action="decrease"
                      aria-label="Decrease quantity"
                    >
                      −
                    </button>
                    <span class="w-7 text-center text-xs font-medium text-bark drawer-qty-value">
                      {{ item.quantity }}
                    </span>
                    <button
                      class="drawer-qty-btn w-6 h-6 bg-sand flex items-center justify-center text-bark text-xs hover:bg-sand-dark transition-colors cursor-pointer"
                      data-item-key="{{ item.key }}"
                      data-action="increase"
                      aria-label="Increase quantity"
                    >
                      +
                    </button>
                  </div>
                  <span class="text-sm font-medium text-mango-dark">
                    {{ item.line_price | money }}
                  </span>
                </div>

                <button
                  class="drawer-remove-btn text-[10px] text-red-400 hover:text-red-600 transition-colors mt-1.5 cursor-pointer block"
                  data-item-key="{{ item.key }}"
                  aria-label="Remove {{ item.product.title }}"
                >
                  Remove
                </button>
              </div>
            </div>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="text-center py-16">
        <div class="text-4xl mb-3 opacity-25">🛒</div>
        <p class="text-sm text-bark/50">Your cart is empty</p>
        <a
          href="{{ routes.all_products_collection_url }}"
          class="inline-block mt-4 text-xs text-custom-green font-medium hover:underline"
        >
          Start Shopping
        </a>
      </div>
    {%- endif -%}
  </div>

  {%- if cart.item_count > 0 -%}
    <div class="flex-shrink-0 border-t border-bark/10 px-5 py-4 bg-sand space-y-3">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-xs font-medium text-bark">🎁 Gift Wrapping</div>
          <div class="text-[10px] text-bark/50">+₱35 — kraft wrap & card</div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          {%- assign gift_id_number = settings.global_gift_wrap_variant_id | plus: 0 -%}
          {%- assign drawer_gift_items = cart.items | where: 'variant_id', gift_id_number -%}

          <input
            type="checkbox"
            id="cart-gift-toggle"
            class="sr-only peer drawer-gift-toggle"
            data-gift-variant-id="{{ settings.global_gift_wrap_variant_id }}"
            {% if drawer_gift_items.size > 0 %}
              checked
            {% endif %}
          >
          <div
            class="
              w-8 h-4 bg-bark/20 rounded-full transition-colors peer-checked:bg-custom-green
              after:content-[''] after:absolute after:top-0.5 after:left-0.5
              after:bg-white after:rounded-full after:h-3 after:w-3
              after:transition-all peer-checked:after:translate-x-4
            "
          ></div>
        </label>
      </div>
      <div
        id="gift-message-wrap"
        class="{% if drawer_gift_items.size == 0 %}hidden{% endif %} mt-3"
      >
        <input
          type="text"
          id="cart-gift-message"
          placeholder="Your message e.g. Happy Birthday! 🌴"
          value="{{ cart.attributes.gift_message | escape }}"
          class="w-full border border-bark/10 rounded-lg px-3 py-2 text-xs bg-white outline-none focus:border-custom-green transition-colors"
        >
      </div>

      <div class="flex items-center justify-between text-sm">
        <span class="text-bark/60">Subtotal</span>
        <span class="font-medium text-bark" id="drawer-subtotal">
          {{ cart.total_price | money }}
        </span>
      </div>

      <a
        href="/checkout"
        class="block w-full bg-custom-green text-white text-center font-medium text-sm py-3 rounded-xl hover:bg-custom-green-dark transition-colors"
      >
        Checkout → <span class="checkout-total-price">{{ cart.total_price | money }}</span>
      </a>
      <a
        href="{{ routes.cart_url }}"
        class="block w-full border border-custom-green text-custom-green text-center text-sm py-2.5 rounded-xl hover:bg-custom-green/5 transition-colors"
      >
        View Cart
      </a>

      <button
        class="drawer-clear-cart-btn block w-full text-center text-xs text-red-400 hover:text-red-600 transition-colors py-1 cursor-pointer"
        aria-label="Clear all items from cart"
      >
        Clear Cart
      </button>
    </div>
  {%- endif -%}
</div>
