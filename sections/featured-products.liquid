<section class="py-14 px-6 max-w-5xl mx-auto">
  <div class="text-[10px] font-medium uppercase tracking-widest text-mango mb-1">{{ section.settings.label }}</div>
  <h2 class="font-display text-2xl font-bold text-bark mb-2">{{ section.settings.title }}</h2>
  <p class="text-sm text-bark/60 mb-8">{{ section.settings.subtitle }}</p>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    {%- for product in section.settings.collection.products limit: 4 -%}
      {% render 'product-card', product: product %}
    {%- endfor -%}
  </div>
  <div class="text-center mt-8">
    <a
      href="{{ section.settings.collection.url }}"
      class="border border-cebu-green text-cebu-green text-sm font-medium px-6 py-2.5 rounded-lg hover:bg-cebu-green hover:text-white transition"
    >
      View All Products →
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Best Sellers" },
    { "type": "text", "id": "title", "label": "Title", "default": "Lami Kaayo Picks" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Our most-loved Cebu delicacies." },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
