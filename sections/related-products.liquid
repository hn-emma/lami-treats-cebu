<div class="bg-sand py-12 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-[10px] font-medium uppercase tracking-widest text-mango mb-1">
      {{ section.settings.label }}
    </div>
    <h2 class="font-display text-2xl font-bold text-bark mb-6">
      {{ section.settings.title }}
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="related-products-grid" data-product-id="{{ product.id }}">
      {%- for i in (1..4) -%}
        <div class="bg-white rounded-2xl overflow-hidden border border-bark/10 animate-pulse">
          <div class="aspect-square bg-sand-dark"></div>
          <div class="p-4">
            <div class="h-3 bg-sand-dark rounded w-3/4 mb-2"></div>
            <div class="h-3 bg-sand-dark rounded w-1/2"></div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script src="{{ 'related-products.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Related Products",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "You May Also Like"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "More from our store"
    }
  ],
  "presets": [{ "name": "Related Products" }]
}
{% endschema %}
