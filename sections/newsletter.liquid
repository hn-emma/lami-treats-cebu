<section class="bg-mango py-14 px-6">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="font-display text-2xl font-bold text-bark mb-3">
      {{ section.settings.title }}
    </h2>
    <p class="text-sm text-bark/70 mb-7">
      {{ section.settings.subtitle }}
    </p>

    <newsletter-form>
      {%- form 'customer', id: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <div class="py-3 px-5 bg-white/30 rounded-xl">
            <p class="text-sm text-bark font-medium">🌴 Salamat! Check your inbox to confirm your subscription.</p>
          </div>
        {%- else -%}
          <div class="flex gap-2 justify-center flex-wrap" id="newsletter-input-row">
            <input
              type="email"
              name="contact[email]"
              id="newsletter-email"
              placeholder="{{ section.settings.placeholder }}"
              required
              autocomplete="email"
              class="px-4 py-3 rounded-lg text-sm bg-white/90 text-bark outline-none focus:ring-2 focus:ring-bark/30 w-64 font-body"
            >
            <button
              type="submit"
              id="newsletter-submit"
              class="bg-bark text-mango-light text-sm font-medium px-6 py-3 rounded-lg hover:bg-bark/90 transition-colors duration-200 cursor-pointer"
            >
              {{ section.settings.btn_label }}
            </button>
          </div>

          {%- if form.errors -%}
            <div class="mt-4 text-sm text-red-800 bg-red-100 py-2 px-4 rounded-lg">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endform -%}
    </newsletter-form>
  </div>
</section>

<script src="{{ 'newsletter-form.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Get Cebu in Your Inbox 🌴"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "New products, exclusive bundles, and pasalubong promos — straight to you."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Subscribe →"
    }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
