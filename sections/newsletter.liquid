<section class="bg-mango py-14 px-6">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="font-display text-2xl font-bold text-bark mb-3">
      {{ section.settings.title }}
    </h2>
    <p class="text-sm text-bark/70 mb-7">
      {{ section.settings.subtitle }}
    </p>

    {%- form 'customer', id: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="flex gap-2 justify-center flex-wrap">
        <input
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.placeholder }}"
          required
          class="px-4 py-3 rounded-lg text-sm bg-white/90 text-bark outline-none focus:ring-2 focus:ring-bark/30 w-64 font-body"
        >
        <button
          type="submit"
          class="bg-bark text-mango-light text-sm font-medium px-6 py-3 rounded-lg hover:bg-bark/90 transition-colors duration-200"
        >
          {{ section.settings.btn_label }}
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="mt-4 text-sm text-bark font-medium">🎉 You're subscribed! Salamat!</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Get Cebu in Your Inbox 🌴"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "New products, exclusive bundles, and pasalubong promos — straight to you."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Subscribe →"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
