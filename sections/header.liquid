<nav class="bg-cebu-green sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="font-display text-lg font-bold text-mango-light">
      🌴 Lami <span class="text-mango">Cebu</span>
    </a>
    <div class="hidden md:flex gap-6">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="text-xs text-white/75 hover:text-white transition">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </div>
    <div class="flex items-center gap-3">
      <a href="/search" class="text-white/70 hover:text-white text-sm">🔍</a>
      <a href="/wishlist" class="text-white/70 hover:text-white text-sm">♡</a>
      <button id="cart-drawer-trigger" class="relative text-white/70 hover:text-white text-sm">
        🛒
        <span class="absolute -top-1 -right-2 bg-mango text-bark text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center">
          {{ cart.item_count }}
        </span>
      </button>
    </div>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [{ "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" }]
}
{% endschema %}
